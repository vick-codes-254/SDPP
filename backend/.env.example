# ════════════════════════════════════════════════════════════════
#  SDPP — Environment Configuration TEMPLATE
#  Copy to `.env` and fill in. NEVER commit the real `.env`.
#  Generate strong values with:  python -m app.cli gen-secrets
# ════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────
APP_NAME="Secure Data Protection Platform"
APP_ENV=development            # development | staging | production
DEBUG=true                     # MUST be false in production
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ── Server / CORS ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed browser origins (no wildcard in prod)
CORS_ORIGINS=http://localhost:5173,https://localhost

# ── Database ────────────────────────────────────────────────────
# Async driver (asyncpg) for the app:
DATABASE_URL=postgresql+asyncpg://sdpp:sdpp_pw@localhost:5432/sdpp
# Sync driver (psycopg) for Alembic migrations:
DATABASE_URL_SYNC=postgresql+psycopg://sdpp:sdpp_pw@localhost:5432/sdpp

# ── JWT / Sessions ──────────────────────────────────────────────
# 32+ byte random secret (base64). Used to sign access/refresh tokens.
JWT_SECRET_KEY=CHANGE_ME_base64_32_bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=sdpp
JWT_AUDIENCE=sdpp-clients

# ── Key Management Service (KMS) ────────────────────────────────
# Provider for the Master Key (Key-Encrypting-Key, KEK):
#   local  -> master key from MASTER_KEY env var (dev / on-prem)
#   aws    -> AWS KMS
#   azure  -> Azure Key Vault
#   vault  -> HashiCorp Vault
KMS_PROVIDER=local

# LOCAL provider: base64-encoded 32-byte (256-bit) master key.
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY=CHANGE_ME_base64_32_byte_master_key
# Optional: previous master key(s) to support rotation (comma-separated, newest first)
MASTER_KEY_PREVIOUS=

# AWS KMS (when KMS_PROVIDER=aws)
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1

# Azure Key Vault (when KMS_PROVIDER=azure)
AZURE_KEY_VAULT_URL=
AZURE_KEY_NAME=

# HashiCorp Vault (when KMS_PROVIDER=vault)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_TRANSIT_KEY=sdpp-master

# ── Password Policy (Argon2id) ──────────────────────────────────
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536    # 64 MiB
ARGON2_PARALLELISM=4
ARGON2_HASH_LEN=32
ARGON2_SALT_LEN=16
PASSWORD_MIN_LENGTH=12
PASSWORD_HISTORY_SIZE=5         # disallow reuse of last N passwords
PASSWORD_MAX_AGE_DAYS=90        # force rotation after N days
MAX_FAILED_LOGINS=5            # lock account after N failures
ACCOUNT_LOCKOUT_MINUTES=15

# ── Secure File Vault ───────────────────────────────────────────
VAULT_STORAGE_PATH=./var/vault        # encrypted blobs at rest
MAX_UPLOAD_SIZE_MB=2048               # 2 GiB hard cap
KEY_ROTATION_DAYS=90                  # DEK rotation interval
INTEGRITY_ALGORITHM=sha256

# ── Security Headers / TLS ──────────────────────────────────────
ENABLE_HSTS=true
HSTS_MAX_AGE=63072000                 # 2 years
ENABLE_SECURE_COOKIES=true
